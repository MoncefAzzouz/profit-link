generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AFFILIATE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String   @default("📦")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String
  phone        String?
  wilaya       String?
  ccp          String?
  storeName    String?
  role         Role    @default(AFFILIATE)
  tier         String  @default("المستوى 1 - مبتدئ")

  // Financial
  walletBalance Float @default(0.0)

  // Relations
  orders        Order[] // Affiliate's generated orders
  landingPages  LandingPage[]
  withdrawals   WithdrawalRequest[]
  storeSettings StoreSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AffiliateLevel {
  id           String   @id @default(uuid())
  name         String   @unique
  levelNumber  Int      @unique
  targetOrders Int      @default(0)
  reward       String?
  color        String   @default("blue")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id String @id @default(uuid())

  name          String
  description   String
  adText        String? // Ad copy text
  price         Float // Selling price
  originalPrice Float // Fake discount price
  commission    Float // Affiliate commission

  images   String[] // URLs
  image    String? // Main image URL
  videoUrl String? // Product video URL
  category String
  stock    Int      @default(0)
  status   String   @default("active") // active, out_of_stock, disabled

  wholesalePrice Float @default(0.0) // Real wholesale price
  affiliatePrice Float @default(0.0) // Wholesale price for affiliate

  isVisible  Boolean  @default(true)
  isTrend    Boolean  @default(false)
  isFeatured Boolean  @default(false)
  features   String[] // Product features list

  // Variant options
  hasColors        Boolean  @default(false)
  availableColors  String[]
  hasSizes         Boolean  @default(false)
  availableSizes   String[]
  showFreeShipping Boolean  @default(false)

  // Before and After 
  hasBeforeAfter Boolean @default(false)
  beforeImage    String?
  afterImage     String?

  // Marketing Offers
  hasMarketingOffers Boolean @default(false)
  marketingOffers    Json?

  orders       Order[]
  landingPages LandingPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isVisible, createdAt])
  @@index([category])
}

model Order {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  affiliateId String
  affiliate   User   @relation(fields: [affiliateId], references: [id])

  // Customer Data
  customerName     String
  customerPhone    String
  wilaya           String
  address          String
  quantity         Int    @default(1)
  totalAmount      Float
  commissionAmount Float

  status         OrderStatus @default(PENDING)
  trackingNumber String? // For delivery API
  commune        String? // Name or ID of commune
  shippingFee    Float       @default(0.0)
  stopDesk       Int         @default(0) // 0 for home, 1 for desk

  // Variants selected by customer
  selectedColor String?
  selectedSize  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId])
  @@index([productId])
}

model LandingPage {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Entire visual representation of the page builder saved as flexible JSON
  pageConfig Json

  status      String @default("published")
  views       Int    @default(0)
  conversions Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([productId])
}

model StoreSettings {
  id          String @id @default(uuid())
  affiliateId String @unique
  affiliate   User   @relation(fields: [affiliateId], references: [id])

  storeName    String
  logoUrl      String?
  primaryColor String  @default("#000000")
  fontFamily   String  @default("Cairo")
  templateId   String  @default("modern")

  // Holds hero, usp, socialLinks, pixels, etc.
  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WithdrawalRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount         Float
  method         String // "CCP", "Baridimob"
  accountDetails String
  status         String @default("pending") // pending, approved, rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
